# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Database (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/broomnsblog"

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# CORS — frontend URL
CORS_ORIGIN=http://localhost:3000

# Max comments a single user can have awaiting moderation at once (flood
# protection + bounds the moderation queue). Defaults to 15 if unset.
MAX_PENDING_COMMENTS_PER_USER=15

# Used to build links (newsletter confirm/unsubscribe emails)
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# AWS (fill in when deploying — names must match what infrastructure/lib/stacks/api-stack.ts
# sets on the Lambda; AWS_REGION is injected automatically by the Lambda runtime itself)
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
SES_FROM_EMAIL=
# Media uploads bucket — real uploads/deletes happen against this bucket even
# in local dev if AWS credentials are configured (no local disk/dev fallback).
# Note this only affects where new uploads land — the admin media library
# lists rows from your local Postgres Media table, not the bucket's actual
# contents, so a fresh local DB won't show production's existing images even
# when pointed at the real bucket.
S3_BUCKET_NAME=
