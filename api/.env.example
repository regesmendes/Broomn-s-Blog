# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Database (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/foradoprograma"

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# CORS — frontend URL
CORS_ORIGIN=http://localhost:3000

# Used to build links (newsletter confirm/unsubscribe emails, media file URLs)
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# AWS (fill in when deploying — names must match what infrastructure/lib/stacks/api-stack.ts
# sets on the Lambda; AWS_REGION is injected automatically by the Lambda runtime itself)
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
SES_FROM_EMAIL=
